{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a player in TaskQuest.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "bio": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "notifications": { "type": "boolean" },
            "theme": { "type": "string", "enum": ["light", "dark", "rpg"] }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "tasksCompleted": { "type": "integer" },
            "totalPlayTime": { "type": "integer" }
          }
        }
      },
      "required": ["uid", "email", "xp", "level"]
    },
    "Quest": {
      "title": "Quest",
      "description": "A task that a user or team needs to complete.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Main", "Side", "Daily", "Event"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Epic"] },
        "status": { "type": "string", "enum": ["Active", "Completed", "Failed", "OnHold"] },
        "deadline": { "type": "string", "format": "date-time" },
        "creatorId": { "type": "string" },
        "assignees": { "type": "array", "items": { "type": "string" } },
        "xpReward": { "type": "integer" },
        "teamId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "creatorId", "status", "xpReward"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message sent within a quest or team chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "file"] },
        "attachmentUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "readBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["senderId", "text", "type", "createdAt"]
    },
    "Team": {
      "title": "Team",
      "description": "A group of users collaborating on quests.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "creatorId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "creatorId", "members"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profiles."
    },
    "/quests/{questId}": {
      "schema": "Quest",
      "description": "Global quests or team-specific quests."
    },
    "/quests/{questId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Quest-specific chat messages."
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Collaboration groups."
    },
    "/teams/{teamId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Team-wide chat messages."
    }
  }
}
